{
  "info": {
    "name": "Student Learning Platform - Minimal",
    "_postman_id": "auto-generated",
    "description": "Basic endpoints for testing notifications and auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Get Notifications",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/notifications?limit=50"
      }
    },
    {
      "name": "Dev: Create Notification",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recipientId\": \"{{recipientId}}\",\n  \"type\": \"test\",\n  \"title\": \"Hello\",\n  \"message\": \"This is a test\"\n}"
        },
        "url": "{{baseUrl}}/api/notifications/dev/create"
      }
    },
    {
      "name": "Send Message",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"receiverId\": \"{{recipientId}}\",\n  \"content\": \"Hello there\"\n}"
        },
        "url": "{{baseUrl}}/api/messages/send"
      }
    },
    {
      "name": "Follow User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/users/{{targetUserId}}/follow"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "recipientId", "value": "" },
    { "key": "targetUserId", "value": "" }
  ]
}
