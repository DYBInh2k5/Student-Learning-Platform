{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next@latest"
    },
    {
      "src": "backend/package.json",
      "use": "@vercel/node@latest",
      "config": { "zeroConfig": true }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/.next/($1)"
    }
  ],
  "projectSettings": {
    "sourceFilesOutsideRootDirectory": true
  }
}
